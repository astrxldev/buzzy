{
  "name": "buzzy",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "nextdev": "bun --bun next dev --turbopack",
    "dev": "cd dev && docker compose up --watch --quiet-build",
    "ds": "cd dev && docker compose exec -it app bun",
    "build": "bun --bun next build --turbopack && bun run sentry:sourcemaps",
    "analyze": "ANALYZE=true next build --webpack",
    "start": "bun --bun next start",
    "lint": "biome check --fix",
    "format": "biome format --write",
    "dr": "drizzle-kit",
    "ba": "bunx @better-auth/cli",
    "up": "bun dr push && docker compose build && docker rollout app && docker compose up -d backup backend -t 0 && bun ngreload",
    "logs": "docker compose logs -fn50",
    "ngreload": "docker compose restart -t 0 nginx",
    "test": "playwright test",
    "sentry:sourcemaps": "sentry-cli sourcemaps inject --org astrxldev --project buzz ./.next/server && sentry-cli sourcemaps upload --org astrxldev --project buzz ./.next/server"
  },
  "dependencies": {
    "@bprogress/next": "^3.2.12",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@headless-tree/core": "^1.6.0",

{
  "name": "buzzy",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --bun vite dev --host 0.0.0.0",
    "nextdev": "bun next dev --turbopack",
    "dockerdev": "cd dev && docker compose up --watch --quiet-build",
    "ds": "cd dev && docker compose exec -it app bun",
    "build": "bun vite build",
    "nextbuild": "bun next build --turbopack",
    "analyze": "ANALYZE=true next build --webpack",
    "preview": "bun vite preview --host 0.0.0.0",
    "start": "bun build/index.js",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "lint": "biome check --fix",
    "format": "biome format --write",
    "dr": "drizzle-kit",
    "ba": "bunx @better-auth/cli",
    "up": "bun dr push && docker compose build && docker rollout app && docker compose up -d backup backend -t 0 && bun ngreload",
    "logs": "docker compose logs -fn50",
    "ngreload": "docker compose restart -t 0 nginx",
    "test": "playwright test"
  },

    "react-hook-form": "^7.68.0",
    "react-resizable-panels": "^3.0.6",
    "react-use": "^17.6.0",
    "recharts": "2.15.4",
    "reconnecting-eventsource": "^1.6.4",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.0",
    "usehooks-ts": "^3.1.1",
